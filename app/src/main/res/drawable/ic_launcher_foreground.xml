<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground: a stylised scale dial with a needle.
    108x108 viewport; artwork kept inside the ~66dp central safe zone so the
    system mask (circle/squircle) never clips it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dial ring (center 54,54 radius 26) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:pathData="M28,54 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0" />

    <!-- Needle pointing up-right -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:pathData="M54,54 L67,42" />

    <!-- Center hub -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M49,54 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />

    <!-- Tick marks at base of dial -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M40,74 L42,71 M54,78 L54,74 M68,74 L66,71" />
</vector>
